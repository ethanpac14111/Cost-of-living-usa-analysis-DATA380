# Part 17: NMF with 3 Components
from sklearn.decomposition import NMF
from sklearn.preprocessing import MinMaxScaler

X = df[quantitative_vars]

# NMF needs positive values, so I scaled the data from 0 to 1
nmf_scaler = MinMaxScaler()
X_nmf = nmf_scaler.fit_transform(X)

nmf = NMF(n_components=3, random_state=1, max_iter=1000)
nmf_result = nmf.fit_transform(X_nmf)

nmf_df = pd.DataFrame(
    nmf_result,
    columns=["Component 1", "Component 2", "Component 3"]
)

print("NMF Results:")
print(nmf_df.head())

# sample the data so the graph is easier to read
sample = nmf_df.sample(2000, random_state=1)

plt.figure(figsize=(8,6))

plt.scatter(
    sample["Component 1"],
    sample["Component 2"],
    alpha=0.4,
    s=15
)

plt.title("NMF Plot: Cost Patterns")
plt.xlabel("Component 1 (Overall Cost Intensity)")
plt.ylabel("Component 2 (Cost Pattern Differences)")

plt.text(0.04, 0.03, "Higher Cost Areas", fontsize=10)
plt.text(0.005, 0.12, "Different Cost Mix", fontsize=10)

plt.grid(alpha=0.3)
plt.tight_layout()
plt.show()
